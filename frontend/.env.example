# Copy this file to .env.local and fill in your Cognito values.
# .env.local is gitignored and must never be committed.

# Found in AWS Console → Cognito → User Pools → your pool → Overview
VITE_COGNITO_USER_POOL_ID=eu-north-1_xxxxxxxxx

# Found in AWS Console → Cognito → User Pools → your pool → App clients
VITE_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# The domain prefix shown in Hosted UI settings — bare domain only, no https://
# e.g. myapp.auth.eu-north-1.amazoncognito.com
VITE_COGNITO_DOMAIN=your-prefix.auth.your-region.amazoncognito.com

# Must exactly match a URL registered in the App Client's "Allowed callback URLs"
VITE_COGNITO_REDIRECT_SIGN_IN=http://localhost:5173/admin/callback

# Must exactly match a URL registered in the App Client's "Allowed sign-out URLs"
VITE_COGNITO_REDIRECT_SIGN_OUT=http://localhost:5173
